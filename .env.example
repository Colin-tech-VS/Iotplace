# Copier vers .env pour le développement local (ne jamais committer .env)
FLASK_ENV=development
SECRET_KEY=dev-secret-change-me
SITE_URL=http://localhost:5050
# Production (Scalingo): https://iotplace.fr

CRM_ADMIN_USERNAME=iotplace_admin
CRM_ADMIN_PASSWORD=change-me

# Mistral AI — génération de pages vitrine (ne jamais committer la vraie clé)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# SMTP / IMAP — CRM emailing (boîte LWS contact@iotplace.fr)
SMTP_HOST=mail96.lwspanel.com
SMTP_PORT=587
SMTP_USER=contact@iotplace.fr
SMTP_PASSWORD=
SMTP_FROM_EMAIL=contact@iotplace.fr
SMTP_FROM_NAME=Iotplace
SMTP_USE_TLS=true
IMAP_HOST=mail96.lwspanel.com
IMAP_PORT=993
IMAP_USER=contact@iotplace.fr
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_USE_SSL=true

# Stripe Connect — paiements & séquestre (ne jamais committer les vraies clés)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
IOTPLACE_COMMISSION_PERCENT=10
IOTPLACE_POC_APPLICATION_FEE_EUR=49
IOTPLACE_POC_APPLICATION_COMMISSION_PERCENT=100
IOTPLACE_PRO_COMMISSION_PERCENT=7
IOTPLACE_PRO_PRICE_EUR=399
# Optionnel : ID Stripe Price pour l'abonnement Pro (sinon créé automatiquement)
STRIPE_PRO_PRICE_ID=

# Persistance — dev: JSON local | prod: PostgreSQL ou Supabase REST
# IOTPLACE_DATA_BACKEND=auto
# IOTPLACE_DATA_DIR=./data
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_KEY=sb_publishable_...
# SUPABASE_DB_HOST=aws-1-eu-central-1.pooler.supabase.com
